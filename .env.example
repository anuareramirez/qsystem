# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Número de reverse proxies de confianza entre cliente y Django. Usado por
# django-axes y por el logging de IPs en magic-link/PIN para resistir spoofing
# de X-Forwarded-For.
#   0 = Django expuesto directo (dev local).
#   1 = un único nginx/ALB delante.
#   2 = CDN (CloudFront) + nginx/ALB.
TRUSTED_PROXY_COUNT=0

# Database
DB_NAME=qsystem
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Email Settings (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@qsystem.com

# AWS S3 Settings (Optional)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Microsoft Graph API (Optional - for email integration)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Frontend
VITE_API_URL=http://localhost:8000

# Hardening HTTP (solo aplican en settings/prod.py)
# Duración del header HSTS en segundos. Empieza con 3600 (1h) y, una vez
# validado que HTTPS está sano, sube a 31536000 (1 año). HSTS es cacheado
# por el navegador: un downgrade a HTTP rompe acceso durante este período.
SECURE_HSTS_SECONDS=3600
# Incluir en la lista preload de Chrome/Firefox (requiere submit manual en
# hstspreload.org). Solo activar cuando HSTS_SECONDS=31536000.
SECURE_HSTS_PRELOAD=False